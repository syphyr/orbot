<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bottom_sheet_rounded"
    android:paddingStart="@dimen/bottom_sheet_constraint_padding"
    android:paddingEnd="@dimen/bottom_sheet_constraint_padding">

    <View
        android:id="@+id/handle"
        android:layout_width="30dp"
        android:layout_height="5dp"
        android:layout_marginTop="16dp"
        android:background="@android:color/darker_gray"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvConfigHeader"
        style="@style/BottomSheetHeader"
        android:layout_margin="16dp"
        android:text="@string/kindness_usage_limit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/handle" />

    <TextView
        android:id="@+id/tvCustomBridgeSubHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="16dp"
        android:text="@string/kindness_config_detail"
        android:textColor="@android:color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvConfigHeader" />

    <TextView
        android:id="@+id/tvOptionOnlyOnWifi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="40dp"
        android:text="@string/option_only_on_wifi"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCustomBridgeSubHeader" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/swKindnessConfigWifi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:contentDescription="@string/option_only_on_wifi"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:checked="true"
        app:layout_constraintBottom_toBottomOf="@id/tvOptionOnlyOnWifi"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvOptionOnlyOnWifi"
        app:showText="false" />


    <TextView
        android:id="@+id/tvOptionOnlyWhenCharging"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="@string/option_only_when_charging"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/swKindnessConfigWifi" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/swKindnessConfigCharging"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@id/tvOptionOnlyWhenCharging"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvOptionOnlyWhenCharging"
        app:showText="false" />


    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/mainGuideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="@dimen/bottom_sheet_btn_guideline_percent" />

    <TextView
        android:id="@+id/tvCancel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/bottom_sheet_btn_padding"
        android:paddingEnd="@dimen/bottom_sheet_btn_padding"
        android:text="@android:string/cancel"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        app:layout_constraintBaseline_toBaselineOf="@id/btnAction"
        app:layout_constraintEnd_toStartOf="@id/btnAction"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnAction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:background="@drawable/btn_shape_round"
        android:paddingStart="@dimen/bottom_sheet_btn_padding"
        android:paddingEnd="@dimen/bottom_sheet_btn_padding"
        android:text="@string/save"
        android:textColor="@android:color/white"
        app:backgroundTint="@color/orbot_btn_enabled_purple"
        app:layout_constraintEnd_toEndOf="@id/tvCancel"
        app:layout_constraintStart_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mainGuideline" />

</androidx.constraintlayout.widget.ConstraintLayout>