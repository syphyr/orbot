<?xml version="1.0" encoding="utf-8"?>

<resources>

    <style name="DefaultTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/new_background</item>
        <item name="android:windowBackground">@color/new_background</item>
        <item name="android:windowIsFloating">false</item>
        <item name="colorPrimaryDark">@color/new_background</item>
        <item name="preferenceTheme">@style/PrefsTheme</item>
        <item name="alertDialogTheme">@style/OrbotDialogTheme</item>
    </style>

    <style name="OrbotDialogTheme" parent="Theme.Material3.Light.Dialog.Alert">
        <item name="android:background">@color/dark_purple</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textColorPrimary">@android:color/white</item>
        <item name="android:textColorSecondary">@android:color/white</item>
        <item name="android:layout_gravity">left</item>
    </style>
</resources>

